--- ag_test: console load/conformity driver for the offline guard. Dormant until toggled.
---
--- Console:
---   run_string ag_test.run()   toggle the driver; it does everything on its own
---
--- On start it auto-picks a smart on a level away from the actor (so squads spawn offline
--- and the offline guard actually engages), then every 10s spawns one squad there through
--- SIMBOARD:create_squad and logs a conformity snapshot to alifeguard.log:
---   [DRIVER] spawned=N                          load climbing
---   [CONFORM] cell=L:X:Z count=C                independent per-cell offline count; must
---                                               match the guard's own [DENSITY] pass line
---   [CONFORM] hub=<smart> bodies=B cmd=K protected=P scripted=S named=M
---                                               watch bodies rise then drop to ~max after
---                                               [OFFLINE-CULL]; cmd/protected/named never fall
---   [CONFORM] audit=<smart> npc_info=I(stale J) arriving=A(stale K)
---                                               stale must be 0 after a cull
--- Toggle run() again to stop. Capped at 200 spawned squads.

local pairs, math_floor, string_format, tostring = pairs, math.floor, string.format, tostring
local alife_object, alife, game_graph = alife_object, alife, game_graph
local get_story_id = get_object_story_id
local xlog, xsquad, xlevel, xdata = xlog, xsquad, xlevel, xdata

local log = xlog.get_logger("AG.TEST", { outfile = "alifeguard.log" })

local TICK_SEC = 10
local FEED_MAX = 200
local TIME_EVENT_ID = "ag_test"
local TIME_EVENT_ACTION = "driver"
local SECTIONS = { "stalker_sim_squad_novice", "bandit_sim_squad_novice", "simulation_dog" }

local _active = false
local _target_name = nil
local _spawned = 0
local _section_idx = 0

local _protection_opts = {
    exclude_scripted = false,
    exclude_permanent = true,
    exclude_active_role = true,
    exclude_task_target = true,
}

local function _tip(msg)
    log.info("%s", msg)
    if db and db.actor then news_manager.send_tip(db.actor, msg, nil, nil, 6000) end
end

-- Pick a smart on a level other than the actor's, so spawns land offline and the guard
-- processes them. Returns name + server object, or nil if the world has one level only.
local function _pick_offline_smart(graph, actor_level)
    if not (SIMBOARD and SIMBOARD.smarts_by_names) then return nil end
    for name, smart in pairs(SIMBOARD.smarts_by_names) do
        local gvid = smart.m_game_vertex_id
        local ok = gvid and graph:valid_vertex_id(gvid) and graph:vertex(gvid):level_id() ~= actor_level
        if ok then return name, smart end
    end
    return nil
end

local function _spawn_one(smart, name)
    _section_idx = _section_idx + 1
    local section = SECTIONS[(_section_idx % #SECTIONS) + 1]
    local squad = xsquad.create_squad(smart, section)
    if not squad then return end
    _spawned = _spawned + 1
    log.info("[DRIVER] spawned=%d squad=%d sec=%s smart=%s", _spawned, squad.id, section, name)
end

-- ==================== CONFORMITY SNAPSHOT ====================

local function _bin_offline(squad_id, graph, actor_level, cell_size, counts)
    local squad = alife_object(squad_id)
    if not squad or squad.online then return end
    local body_count = squad:npc_count()
    if body_count == 0 then return end
    local gvid = squad.m_game_vertex_id
    if not gvid or not graph:valid_vertex_id(gvid) then return end
    local level_id = graph:vertex(gvid):level_id()
    if level_id == actor_level then return end
    local pos = squad.position
    if not pos then return end
    local key = level_id .. ":" .. math_floor(pos.x / cell_size) .. ":" .. math_floor(pos.z / cell_size)
    counts[key] = (counts[key] or 0) + body_count
end

local function _log_offline_cells(graph, actor_level, cell_size)
    local counts = {}
    for squad_id in pairs(SIMBOARD.squads) do
        _bin_offline(squad_id, graph, actor_level, cell_size, counts)
    end
    for key, count in pairs(counts) do
        log.info("[CONFORM] cell=%s count=%d", key, count)
    end
end

local function _count_named(squad, commander_id)
    local named = 0
    for member_id in xsquad.iter_member_ids(squad) do
        local se = member_id ~= commander_id and alife_object(member_id)
        if se and (get_story_id(member_id) or xdata.unscriptable_npcs[se:section_name()]) then named = named + 1 end
    end
    return named
end

local function _tally_hub(squad_id, smart_pos, max_dist_sqr, totals)
    local squad = alife_object(squad_id)
    if not squad or not squad.position then return end
    if smart_pos:distance_to_sqr(squad.position) > max_dist_sqr then return end
    totals.bodies = totals.bodies + squad:npc_count()
    totals.cmd = totals.cmd + 1
    totals.protected = totals.protected + (xsquad.is_protected(squad, _protection_opts) and 1 or 0)
    totals.scripted = totals.scripted + (xsquad.is_scripted(squad) and 1 or 0)
    totals.named = totals.named + _count_named(squad, squad:commander_id())
end

local function _log_hub(smart, name, max_dist_sqr)
    local smart_pos = smart.position
    local totals = { bodies = 0, cmd = 0, protected = 0, scripted = 0, named = 0 }
    for squad_id in pairs(SIMBOARD.squads) do
        _tally_hub(squad_id, smart_pos, max_dist_sqr, totals)
    end
    log.info("[CONFORM] hub=%s bodies=%d cmd=%d protected=%d scripted=%d named=%d",
        name, totals.bodies, totals.cmd, totals.protected, totals.scripted, totals.named)
end

local function _audit_table(tbl)
    local total, stale = 0, 0
    for id in pairs(tbl) do
        total = total + 1
        if not alife_object(id) then stale = stale + 1 end
    end
    return total, stale
end

local function _log_audit(smart, name)
    local info_total, info_stale = _audit_table(smart.npc_info or {})
    local arr_total, arr_stale = _audit_table(smart.arriving_npc or {})
    log.info("[CONFORM] audit=%s npc_info=%d(stale %d) arriving=%d(stale %d)",
        name, info_total, info_stale, arr_total, arr_stale)
end

-- ==================== DRIVER ====================

local function _driver_tick()
    ResetTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION, TICK_SEC)
    if not _active then return true end
    local sim = alife()
    local graph = game_graph()
    local smart = _target_name and SIMBOARD and SIMBOARD.smarts_by_names and SIMBOARD.smarts_by_names[_target_name]
    if not (sim and graph and smart) then return false end
    local actor_level = xlevel.get_actor_level_id()
    if _spawned < FEED_MAX then _spawn_one(smart, _target_name) end
    local cell_size = sim:switch_distance()
    _log_offline_cells(graph, actor_level, cell_size)
    _log_hub(smart, _target_name, cell_size * cell_size)
    _log_audit(smart, _target_name)
    return false
end

--- Toggle the load/conformity driver. Everything runs on its own; nothing else to call.
function run()
    if _active then
        _active = false
        RemoveTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION)
        _tip(string_format("ag_test: stopped, spawned %d squads at %s", _spawned, tostring(_target_name)))
        return
    end
    local sim = alife()
    local graph = game_graph()
    if not (sim and graph) then _tip("ag_test: alife not ready") return end
    local actor_level = xlevel.get_actor_level_id()
    local name = _pick_offline_smart(graph, actor_level)
    if not name then _tip("ag_test: no smart on another level (need a non-actor level)") return end
    _active = true
    _target_name = name
    RemoveTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION)
    CreateTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION, TICK_SEC, _driver_tick)
    _tip(string_format("ag_test: running, feeding %s every %ds (set density_trigger/target low to force a cull)", name, TICK_SEC))
end
