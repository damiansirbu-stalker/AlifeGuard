--- ag_test: console load/conformity driver for the offline guard, plus flow-integration
--- tests. Dormant until toggled.
---
--- Console:
---   run_string ag_test.run()   toggle the driver; it does everything on its own
---   run_string ag_test.ag_test_inventory_sanitization()   Inventory Guard flow test
---   run_string ag_test.ag_test_trader_purge()   trader stock condition purge flow test
---
--- On start it auto-picks a smart on a level away from the actor (so squads spawn offline
--- and the offline guard actually engages), then every 10s spawns one squad there through
--- SIMBOARD:create_squad and logs a conformity snapshot to alifeguard.log:
---   [DRIVER] spawned=N                          load climbing
---   [CONFORM] cell=L:X:Z count=C                independent per-cell offline count; must
---                                               match the guard's own [DENSITY] pass line
---   [CONFORM] hub=<smart> bodies=B cmd=K protected=P scripted=S named=M
---                                               watch bodies rise then drop to ~max after
---                                               [OFFLINE-CULL]; cmd/protected/named never fall
---   [CONFORM] audit=<smart> npc_info=I(stale J) arriving=A(stale K)
---                                               stale must be 0 after a cull
--- Toggle run() again to stop. Capped at 200 spawned squads.

local pairs, math_floor, string_format, tostring = pairs, math.floor, string.format, tostring
local alife_object, alife, game_graph = alife_object, alife, game_graph
local get_story_id = get_object_story_id
local xlog, xsquad, xlevel, xdata = xlog, xsquad, xlevel, xdata

local log = xlog.get_logger("AG.TEST", { outfile = "alifeguard.log" })

local TICK_SEC = 10
local FEED_MAX = 200
local TIME_EVENT_ID = "ag_test"
local TIME_EVENT_ACTION = "driver"
local SECTIONS = { "stalker_sim_squad_novice", "bandit_sim_squad_novice", "simulation_dog" }

local _active = false
local _target_name = nil
local _spawned = 0
local _section_idx = 0

local _protection_opts = {
    exclude_scripted = false,
    exclude_permanent = true,
    exclude_active_role = true,
    exclude_task_target = true,
}

local function _tip(msg)
    log.info("%s", msg)
    if db and db.actor then news_manager.send_tip(db.actor, msg, nil, nil, 6000) end
end

-- Pick a smart on a level other than the actor's, so spawns land offline and the guard
-- processes them. Returns name + server object, or nil if the world has one level only.
local function _pick_offline_smart(graph, actor_level)
    if not (SIMBOARD and SIMBOARD.smarts_by_names) then return nil end
    for name, smart in pairs(SIMBOARD.smarts_by_names) do
        local gvid = smart.m_game_vertex_id
        local ok = gvid and graph:valid_vertex_id(gvid) and graph:vertex(gvid):level_id() ~= actor_level
        if ok then return name, smart end
    end
    return nil
end

local function _spawn_one(smart, name)
    _section_idx = _section_idx + 1
    local section = SECTIONS[(_section_idx % #SECTIONS) + 1]
    local squad = xsquad.create_squad(smart, section)
    if not squad then return end
    _spawned = _spawned + 1
    log.info("[DRIVER] spawned=%d squad=%d sec=%s smart=%s", _spawned, squad.id, section, name)
end

-- ==================== CONFORMITY SNAPSHOT ====================

local function _bin_offline(squad_id, graph, actor_level, cell_size, counts)
    local squad = alife_object(squad_id)
    if not squad or squad.online then return end
    local body_count = squad:npc_count()
    if body_count == 0 then return end
    local gvid = squad.m_game_vertex_id
    if not gvid or not graph:valid_vertex_id(gvid) then return end
    local level_id = graph:vertex(gvid):level_id()
    if level_id == actor_level then return end
    local pos = squad.position
    if not pos then return end
    local key = level_id .. ":" .. math_floor(pos.x / cell_size) .. ":" .. math_floor(pos.z / cell_size)
    counts[key] = (counts[key] or 0) + body_count
end

local function _log_offline_cells(graph, actor_level, cell_size)
    local counts = {}
    for squad_id in pairs(SIMBOARD.squads) do
        _bin_offline(squad_id, graph, actor_level, cell_size, counts)
    end
    for key, count in pairs(counts) do
        log.info("[CONFORM] cell=%s count=%d", key, count)
    end
end

local function _count_named(squad, commander_id)
    local named = 0
    for member_id in xsquad.iter_member_ids(squad) do
        local se = member_id ~= commander_id and alife_object(member_id)
        if se and (get_story_id(member_id) or xdata.unscriptable_npcs[se:section_name()]) then named = named + 1 end
    end
    return named
end

local function _tally_hub(squad_id, smart_pos, max_dist_sqr, totals)
    local squad = alife_object(squad_id)
    if not squad or not squad.position then return end
    if smart_pos:distance_to_sqr(squad.position) > max_dist_sqr then return end
    totals.bodies = totals.bodies + squad:npc_count()
    totals.cmd = totals.cmd + 1
    totals.protected = totals.protected + (xsquad.is_protected(squad, _protection_opts) and 1 or 0)
    totals.scripted = totals.scripted + (xsquad.is_scripted(squad) and 1 or 0)
    totals.named = totals.named + _count_named(squad, squad:commander_id())
end

local function _log_hub(smart, name, max_dist_sqr)
    local smart_pos = smart.position
    local totals = { bodies = 0, cmd = 0, protected = 0, scripted = 0, named = 0 }
    for squad_id in pairs(SIMBOARD.squads) do
        _tally_hub(squad_id, smart_pos, max_dist_sqr, totals)
    end
    log.info("[CONFORM] hub=%s bodies=%d cmd=%d protected=%d scripted=%d named=%d",
        name, totals.bodies, totals.cmd, totals.protected, totals.scripted, totals.named)
end

local function _audit_table(tbl)
    local total, stale = 0, 0
    for id in pairs(tbl) do
        total = total + 1
        if not alife_object(id) then stale = stale + 1 end
    end
    return total, stale
end

local function _log_audit(smart, name)
    local info_total, info_stale = _audit_table(smart.npc_info or {})
    local arr_total, arr_stale = _audit_table(smart.arriving_npc or {})
    log.info("[CONFORM] audit=%s npc_info=%d(stale %d) arriving=%d(stale %d)",
        name, info_total, info_stale, arr_total, arr_stale)
end

-- ==================== DRIVER ====================

local function _driver_tick()
    ResetTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION, TICK_SEC)
    if not _active then return true end
    local sim = alife()
    local graph = game_graph()
    local smart = _target_name and SIMBOARD and SIMBOARD.smarts_by_names and SIMBOARD.smarts_by_names[_target_name]
    if not (sim and graph and smart) then return false end
    local actor_level = xlevel.get_actor_level_id()
    if _spawned < FEED_MAX then _spawn_one(smart, _target_name) end
    local cell_size = sim:switch_distance()
    _log_offline_cells(graph, actor_level, cell_size)
    _log_hub(smart, _target_name, cell_size * cell_size)
    _log_audit(smart, _target_name)
    return false
end

--- Toggle the load/conformity driver. Everything runs on its own; nothing else to call.
function run()
    if _active then
        _active = false
        RemoveTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION)
        _tip(string_format("ag_test: stopped, spawned %d squads at %s", _spawned, tostring(_target_name)))
        return
    end
    local sim = alife()
    local graph = game_graph()
    if not (sim and graph) then _tip("ag_test: alife not ready") return end
    local actor_level = xlevel.get_actor_level_id()
    local name = _pick_offline_smart(graph, actor_level)
    if not name then _tip("ag_test: no smart on another level (need a non-actor level)") return end
    _active = true
    _target_name = name
    RemoveTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION)
    CreateTimeEvent(TIME_EVENT_ID, TIME_EVENT_ACTION, TICK_SEC, _driver_tick)
    _tip(string_format("ag_test: running, feeding %s every %ds (set density_trigger/target low to force a cull)", name, TICK_SEC))
end

-- ==================== FLOW TESTS ====================
-- Self-contained @export console functions named ag_test_<flow>(). Each owns its own
-- setup / inject / action / assert / teardown so repeated runs are idempotent. Tests call
-- the SUT (e.g. trim_npc) directly so timing is deterministic. Output goes to a
-- per-session log file appdata/logs/test_alifeguard_<YYYY-MM-DD>_<HH-MM-SS>.log; xlog with
-- explicit flush per line so the file appears immediately. PASS / FAIL also surfaces as a
-- yellow news_manager tip.

local ipairs, type, next = ipairs, type, next
local math_max, math_min, math_huge = math.max, math.min, math.huge
local xcreature, xinventory, xsmart = xcreature, xinventory, xsmart
local IsStalker, IsTrader, level, alife_release_id = IsStalker, IsTrader, level, alife_release_id

local MOD = "alifeguard"

-- session-cached logger for flow tests; one file per game session, appears immediately on disk
local _flow_log
local function _get_flow_log()
    if _flow_log then return _flow_log end
    local ts = os.date("%Y-%m-%d_%H-%M-%S")
    _flow_log = xlog.get_logger("TEST", { outfile = string_format("test_%s_%s.log", MOD, ts) })
    return _flow_log
end

-- xlog facade methods are plain functions (not OO methods). Call with `.`, not `:`.
local function _log_info(msg, ...)
    _get_flow_log().info(msg, ...)
    xlog.flush_all()
end

local function _flow_tip(msg, ms)
    if db and db.actor then news_manager.send_tip(db.actor, msg, nil, nil, ms or 25000) end
end

-- Pick the nearest online stalker that passes xcreature.is_unscriptable.
local function _pick_npc()
    local actor = db.actor
    if not actor then return nil end
    local actor_pos = actor:position()
    local actor_id = actor:id()
    local best, best_dist = nil, math_huge
    for id, obj in xcreature.online_iter_with_id() do
        if id ~= actor_id and alife_object(id) and IsStalker(obj) and obj:alive()
            and not xcreature.is_unscriptable(obj) then
            local dist = obj:position():distance_to_sqr(actor_pos)
            if dist < best_dist then best, best_dist = obj, dist end
        end
    end
    return best
end

-- alife_create_item returns:
--   single cse userdata for non-ammo
--   array of cse for ammo when t.ammo exceeds box_size (engine splits)
local function _extract_ids(se)
    if not se then return {} end
    local se_type = type(se)
    if se_type == "userdata" then
        local id = (type(se.id) == "function" and se:id()) or se.id
        return id and { id } or {}
    end
    if se_type == "table" then
        if se.id then return { se.id } end
        local ids = {}
        for i = 1, #se do
            local cse = se[i]
            local id = cse and ((type(cse.id) == "function" and cse:id()) or cse.id)
            if id then ids[#ids + 1] = id end
        end
        return ids
    end
    return {}
end

local function _inject(npc, sec, count, ammo)
    local all_ids = {}
    for i = 1, count do
        local se = xinventory.create_item(sec, npc:id(), ammo and { ammo = ammo } or nil)
        local ids = _extract_ids(se)
        if #ids == 0 then
            _log_info("[INJECT WARN] %s #%d create returned type=%s (no ids)", sec, i, type(se))
        end
        for _, id in ipairs(ids) do all_ids[#all_ids + 1] = id end
    end
    return all_ids
end

local function _cleanup(ids)
    local released = 0
    for _, id in ipairs(ids or {}) do
        if alife_object(id) then alife_release_id(id); released = released + 1 end
    end
    return released
end

local function _find_mismatched_ammo(opts)
    local candidates = {
        "ammo_9x18_fmj", "ammo_pkm_100", "ammo_gauss",
        "ammo_5.45x39_fmj", "ammo_12x76_dart", "ammo_5.7x28_ss190",
        "ammo_9x39_pab9", "ammo_7.62x54_7h1",
    }
    for _, sec in ipairs(candidates) do
        if ini_sys:section_exist(sec)
            and xinventory.resolve_ammo_category(sec, opts) == "ammo_not_equipped" then
            return sec
        end
    end
    return nil
end

--- Inventory sanitization: ag_inventory_guard.trim_npc end-to-end.
--- Inject 20 medkits + 1 stack of mismatched ammo (200 rounds) into the
--- nearest test-eligible NPC, run trim_npc, assert the per-category release
--- counts match the ceilings in ag_inventory_policy.ltx.
--- @export console
function ag_test_inventory_sanitization()
    local TEST = "inventory_sanitization"
    _log_info("[BEGIN] %s", TEST)

    local npc = _pick_npc()
    if not npc then
        _log_info("[FAIL] %s: no eligible NPC near actor", TEST)
        _flow_tip("[FAIL] " .. TEST .. ": no eligible NPC")
        return
    end
    local npc_id = npc:id()
    local npc_name = npc:name() or "?"
    _log_info("[SETUP] npc=%d name=%s", npc_id, npc_name)

    local opts = xinventory.get_category_opts(npc)
    local before = xinventory.classify(npc, opts)
    _log_info("[SNAPSHOT before] medkit=%d ammo_not_equipped=%d",
        before.medkit or 0, before.ammo_not_equipped or 0)

    local mismatched = _find_mismatched_ammo(opts)
    if not mismatched then
        _log_info("[FAIL] %s: no mismatched ammo section found", TEST)
        _flow_tip("[FAIL] " .. TEST .. ": no mismatched ammo section")
        return
    end

    local INJECT_MEDKIT = 20
    local INJECT_AMMO = 200
    local medkit_ids = _inject(npc, "medkit", INJECT_MEDKIT)
    local ammo_ids = _inject(npc, mismatched, 1, INJECT_AMMO)
    _log_info("[INJECT] medkit ids=%d (requested %d), %s ids=%d (requested 1 stack of %d rounds)",
        #medkit_ids, INJECT_MEDKIT, mismatched, #ammo_ids, INJECT_AMMO)

    -- alife->CInventory sync takes one frame. Defer the assertion by 1 second.
    CreateTimeEvent(0, "ag_test_inv_sanit_phase2", 1, function()
        local npc2 = level.object_by_id(npc_id)
        if not npc2 then
            _log_info("[FAIL] %s: npc went offline before phase 2", TEST)
            _flow_tip("[FAIL] " .. TEST .. ": npc offline")
            _cleanup(medkit_ids); _cleanup(ammo_ids)
            return true
        end

        local opts2 = xinventory.get_category_opts(npc2)
        local mid = xinventory.classify(npc2, opts2)
        local mid_medkit = mid.medkit or 0
        local mid_ammo = mid.ammo_not_equipped or 0
        _log_info("[SNAPSHOT mid] medkit=%d ammo_not_equipped=%d", mid_medkit, mid_ammo)

        local result = ag_inventory_guard.trim_npc(npc2)
        _log_info("[ACTION] trim_npc released=%d dt=%.2fms", result.released, result.dt_ms)
        for cat, count in pairs(result.released_by_category) do
            _log_info("[ACTION]   released %s = %d", cat, count)
        end

        local policy = xinventory.load_policy("alifeguard\\ag_inventory_policy.ltx", { "ag_inventory_policy" })
        local MEDKIT_MAX = policy.ag_inventory_policy.rules.medkit.max
        local expected_medkit_released = math_max(mid_medkit - MEDKIT_MAX, 0)
        local actual_medkit_released = (result.released_by_category.medkit) or 0
        local actual_ammo_released = (result.released_by_category.ammo_not_equipped) or 0
        local expected_medkit_after = math_min(mid_medkit, MEDKIT_MAX)

        local ok_medkit = (actual_medkit_released == expected_medkit_released)
        local ok_ammo = (actual_ammo_released >= 1) and (mid_ammo > 0)

        local summary = string_format(
            "npc=%d %s | medkit %d->%d (released %d, cap %d) | ammo_neq %d (released %d stacks) | dt=%.2fms",
            npc_id, npc_name,
            mid_medkit, expected_medkit_after, actual_medkit_released, MEDKIT_MAX,
            mid_ammo, actual_ammo_released, result.dt_ms)

        _log_info("[SUMMARY] %s", summary)

        if ok_medkit and ok_ammo then
            _log_info("[PASS] %s | %s", TEST, summary)
            _flow_tip(string_format("[PASS] %s\n%s", TEST, summary), 30000)
        else
            local reason = string_format(
                "medkit released=%d expected=%d ok=%s | ammo released=%d expected>=1 (mid=%d) ok=%s",
                actual_medkit_released, expected_medkit_released, tostring(ok_medkit),
                actual_ammo_released, mid_ammo, tostring(ok_ammo))
            _log_info("[FAIL] %s | %s | %s", TEST, summary, reason)
            _flow_tip(string_format("[FAIL] %s\n%s\n%s", TEST, summary, reason), 30000)
        end

        local m_cleaned = _cleanup(medkit_ids)
        local a_cleaned = _cleanup(ammo_ids)
        _log_info("[TEARDOWN] released %d/%d medkit ids, %d/%d ammo ids (others already gone via trim)",
            m_cleaned, #medkit_ids, a_cleaned, #ammo_ids)
        return true
    end)
end

-- Pick the nearest online service NPC (trader/mechanic/medic/barman): the trader-pass
-- eligibility shape (IsStalker or IsTrader, alive, non-empty xsmart.get_npc_roles).
local function _pick_trader()
    local actor = db.actor
    if not actor then return nil end
    local actor_pos = actor:position()
    local actor_id = actor:id()
    local best, best_dist = nil, math_huge
    for id, obj in xcreature.online_iter_with_id() do
        if id ~= actor_id and alife_object(id) and (IsStalker(obj) or IsTrader(obj)) and obj:alive()
            and next(xsmart.get_npc_roles(obj)) ~= nil then
            local dist = obj:position():distance_to_sqr(actor_pos)
            if dist < best_dist then best, best_dist = obj, dist end
        end
    end
    return best
end

local function _find_weapon_section()
    local candidates = { "wpn_pm", "wpn_ak74", "wpn_toz34", "wpn_mp5" }
    for _, sec in ipairs(candidates) do
        if ini_sys:section_exist(sec) and xinventory.get_section_category(sec) == "weapon" then
            return sec
        end
    end
    return nil
end

-- Inject one item at an explicit condition (xinventory.create_item cond path forces the
-- condition onto non-degradable sections like weapons via alife_process_item).
local function _inject_cond(npc, sec, cond)
    local se = xinventory.create_item(sec, npc:id(), { cond = cond })
    local ids = _extract_ids(se)
    if #ids == 0 then
        _log_info("[INJECT WARN] %s create returned type=%s (no ids)", sec, type(se))
    end
    return ids
end

--- Trader stock condition purge: ag_inventory_guard.purge_trader end-to-end.
--- Inject 2 weapons into the nearest service NPC, one below and one above the MCM
--- condition threshold. Dry-run purges before/after injection isolate the delta (only the
--- low-condition weapon may count), then the real purge must release exactly the dry-run set.
--- @export console
function ag_test_trader_purge()
    local TEST = "trader_purge"
    _log_info("[BEGIN] %s", TEST)

    local npc = _pick_trader()
    if not npc then
        _log_info("[FAIL] %s: no service NPC (trader/mechanic/medic/barman) near actor", TEST)
        _flow_tip("[FAIL] " .. TEST .. ": no trader near actor")
        return
    end
    local npc_id = npc:id()
    local npc_name = npc:name() or "?"
    local threshold = ag_mcm.get_config("trader_condition_min") or ag_mcm.defaults.trader_condition_min
    _log_info("[SETUP] trader=%d name=%s threshold=%.2f", npc_id, npc_name, threshold)

    local weapon_sec = _find_weapon_section()
    if not weapon_sec then
        _log_info("[FAIL] %s: no spawnable weapon section found", TEST)
        _flow_tip("[FAIL] " .. TEST .. ": no weapon section")
        return
    end

    local baseline = ag_inventory_guard.purge_trader(npc, { dry_run = true }).released
    local low_cond = math_max(threshold - 0.05, 0.01)
    local high_cond = math_min(threshold + 0.05, 1)
    local low_ids = _inject_cond(npc, weapon_sec, low_cond)
    local high_ids = _inject_cond(npc, weapon_sec, high_cond)
    _log_info("[INJECT] %s low=%.2f ids=%d, high=%.2f ids=%d (baseline dry-run released=%d)",
        weapon_sec, low_cond, #low_ids, high_cond, #high_ids, baseline)

    -- alife->CInventory sync takes one frame. Defer the assertion by 1 second.
    CreateTimeEvent(0, "ag_test_trader_purge_phase2", 1, function()
        local npc2 = level.object_by_id(npc_id)
        if not npc2 then
            _log_info("[FAIL] %s: trader went offline before phase 2", TEST)
            _flow_tip("[FAIL] " .. TEST .. ": trader offline")
            _cleanup(low_ids); _cleanup(high_ids)
            return true
        end

        local mid = ag_inventory_guard.purge_trader(npc2, { dry_run = true }).released
        local result = ag_inventory_guard.purge_trader(npc2)
        local expected_mid = baseline + #low_ids

        local ok_low = mid == expected_mid
        local ok_real = result.released == mid

        local summary = string_format(
            "trader=%d %s | %s low=%.2f high=%.2f threshold=%.2f | dry-run %d->%d (expected %d) | released=%d dt=%.2fms",
            npc_id, npc_name, weapon_sec, low_cond, high_cond, threshold,
            baseline, mid, expected_mid, result.released, result.dt_ms)
        _log_info("[SUMMARY] %s", summary)

        if ok_low and ok_real then
            _log_info("[PASS] %s | %s", TEST, summary)
            _flow_tip(string_format("[PASS] %s\n%s", TEST, summary), 30000)
        else
            local reason = string_format(
                "dry-run delta==low injection ok=%s (high must not count) | real released==dry-run ok=%s",
                tostring(ok_low), tostring(ok_real))
            _log_info("[FAIL] %s | %s | %s", TEST, summary, reason)
            _flow_tip(string_format("[FAIL] %s\n%s\n%s", TEST, summary, reason), 30000)
        end

        local l_cleaned = _cleanup(low_ids)
        local h_cleaned = _cleanup(high_ids)
        _log_info("[TEARDOWN] released %d/%d low ids, %d/%d high ids (others already gone via purge)",
            l_cleaned, #low_ids, h_cleaned, #high_ids)
        return true
    end)
end
